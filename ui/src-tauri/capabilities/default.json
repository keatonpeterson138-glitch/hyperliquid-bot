{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Capabilities for the main window: sidecar spawn of the Python backend.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/backend-sidecar",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            "8787"
          ]
        }
      ]
    }
  ]
}
