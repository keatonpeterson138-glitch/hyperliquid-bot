# ── Wallet ──────────────────────────────────────────────────
PRIVATE_KEY=your_private_key_here_no_0x_prefix
WALLET_ADDRESS=0xYourWalletAddressHere
USE_TESTNET=true

# ── Default Trading Config ──────────────────────────────────
SYMBOL=BTC
MAX_LEVERAGE=3
STRATEGY=ema_crossover
CANDLE_INTERVAL=1h
LOOP_INTERVAL_SEC=15
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
MAX_OPEN_POSITIONS=3
MAX_DAILY_LOSS_USD=100.0

# ── Email Alerts (optional) ────────────────────────────────
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=your_email@gmail.com

# ── Telegram Alerts (optional) ─────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Slot Config (optional — configure via Settings tab) ────
# SLOT_1=BTC|1h|ema_crossover|2.0|4.0|3|false|1000.0|{}|false|false|true|false|true|true|false|30.0|70.0
# SLOT_2=
# SLOT_3=
# SLOT_4=
# SLOT_5=
